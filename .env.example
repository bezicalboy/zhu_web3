# ── Database ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zhu_platform

# ── HD Wallet ──
# Generate with: node -e "const {ethers}=require('ethers');console.log(ethers.Mnemonic.entropyToPhrase(ethers.randomBytes(16)))"
MASTER_MNEMONIC=your_bip39_mnemonic_here

# ── Blockchain (Base Sepolia) ──
RPC_URL=https://sepolia.base.org
ZHU_CONTRACT_ADDRESS=0xYOUR_ZHU_TOKEN_ADDRESS
CHAIN_ID=84532
REQUIRED_CONFIRMATIONS=3

# ── Treasury ──
# Derivation index 0 is reserved for the treasury wallet
TREASURY_INDEX=0

# ── Auth ──
JWT_SECRET=change_this_to_a_random_secret

# ── Service Intervals ──
SCANNER_INTERVAL_MS=15000
SWEEP_INTERVAL_MS=1800000
WITHDRAWAL_INTERVAL_MS=60000

# ── Limits ──
MIN_DEPOSIT_AMOUNT=1
MIN_WITHDRAWAL_AMOUNT=1

# ── Server ──
PORT=3000
